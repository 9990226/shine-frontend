{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shine/local-state",
  "title": "SHINE Frontend localStorage State",
  "type": "object",
  "properties": {
    "applicantName": { "type": "string" },
    "universalLetter": { "type": "string" },
    "keywords": { "type": "string" },
    "blacklist": { "type": "string" },
    "searchUrls": { "type": "string" },
    "cvUrl": { "type": "string" },
    "scanOnLogin": { "type": "boolean" },
    "dailyAutoEnabled": { "type": "boolean" },
    "successfulThisMonth": { "type": "integer", "minimum": 0 },
    "hoursSavedThisYear": { "type": "number", "minimum": 0 },
    "logs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "time": { "type": "string" },
          "email": { "type": "string" },
          "delay_seconds": { "type": "number" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}